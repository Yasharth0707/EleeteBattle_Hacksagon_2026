{
  "manifest_version": 3,
  "name": "EleeteBattle Auto-Sync",
  "version": "1.0",
  "description": "Automatically inject your LeetCode session cookies into EleeteBattle.",
  "icons": {
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.png"
  },
  "permissions": [
    "cookies",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "*://*/*"
  ]
}
